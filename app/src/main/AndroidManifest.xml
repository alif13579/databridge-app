<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🔐 Core Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- 🔔 Notifications (Android 13+ only) -->
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        android:minSdkVersion="33" />

    <!-- 🚀 Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- FOREGROUND_SERVICE_DATA_SYNC is Android 14+ only -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        android:minSdkVersion="34" />

    <!-- 📞 Alerts & Dialer -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 📷 Camera Hardware Feature (required=false → camera ছাড়া devices-এও install হবে) -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".DataBridgeApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DataBridge"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- 🚀 Splash Activity (LAUNCHER - প্রথম স্ক্রিন) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🏠 MainActivity (NoActionBar + ড্রয়ার সাপোর্ট) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.DataBridge"
            android:windowSoftInputMode="adjustResize" />

        <!-- 📷 ML Kit scanner Activity (CameraX + Google Barhopper) -->
        <activity
            android:name=".MlKitScannerActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:theme="@style/Theme.DataBridge"
            tools:replace="android:screenOrientation" />

        <!-- 📞 CallActivity: transparent activity for background/lockscreen auto-dial -->
        <activity
            android:name=".CallActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true" />

        <!-- 🚀 Foreground Service: DataBridgeService (ডাটা সিঙ্ক + অটো-ডায়াল) -->
        <!-- foregroundServiceType="dataSync" is API 29+ only; tools:targetApi suppresses lint -->
        <!-- Android 9 (API 28) will safely ignore foregroundServiceType at parse time -->
        <service
            android:name=".DataBridgeService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            tools:targetApi="29" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
