<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <!-- AppBarLayout: collapsing banner with pinned toolbar inside CTL -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <!-- CollapsingToolbarLayout: banner exits, toolbar pinned (NO contentScrim → no fade) -->
        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:minHeight="52dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:titleEnabled="false">

            <!-- Banner image (fills full height) -->
            <ImageView
                android:id="@+id/ivBranchDetailImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#0d1533"
                android:contentDescription="Branch image" />

            <!-- Glass info overlay at bottom – scrolls away with banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:background="#CC070c1f"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="10dp"
                app:layout_collapseMode="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvDetailBranchCode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#aaaaaa"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvDetailBranchStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:text="● Active"
                        android:textColor="#4ade80"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvDetailBranchType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#00d4ff"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/bg_role_badge"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetailBranchAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#cccccc"
                    android:textSize="12sp"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvDetailBranchManager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#aaaaaa"
                    android:textSize="12sp"
                    android:layout_marginBottom="2dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDetailBranchEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvDetailBranchPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetailBranchParent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Toolbar – pinned at top of CTL, fully opaque, never fades -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#16213e"
                android:paddingStart="4dp"
                android:paddingEnd="12dp"
                android:layout_gravity="top"
                app:layout_collapseMode="pin">

                <TextView
                    android:id="@+id/tvBackDetail"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="←"
                    android:textColor="#ffffff"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/tvBranchDetailTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Branch Details"
                    android:textColor="#ffffff"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingStart="4dp"/>

                <ImageView
                    android:id="@+id/ivEditBranchDetail"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Edit Branch"
                    android:visibility="gone"
                    app:tint="#00d4ff"/>

            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

        <!-- Sticky bar: search + chips + team count – pinned, never scrolls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16213e">

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0d1533"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etEmployeeSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Search by name, ID or email..."
                    android:textColor="#eeeeee"
                    android:textColorHint="#444444"
                    android:textSize="13sp"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0d1533"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/llDetailRoleChips"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />
            </HorizontalScrollView>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0d1533"/>

            <TextView
                android:id="@+id/tvTeamCount"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Team Members"
                android:textColor="#aaaaaa"
                android:textSize="12sp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#0f3460"/>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0d1533"/>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Employee list – fills remaining space, scroll drives AppBar collapse -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ProgressBar
            android:id="@+id/pbEmployeesLoading"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#00d4ff"
            android:visibility="visible"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBranchEmployees"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:scrollbars="vertical"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvEmployeesEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No team members found."
            android:textColor="#aaaaaa"
            android:textSize="14sp"
            android:textAlignment="center"
            android:visibility="gone"/>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
