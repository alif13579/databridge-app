<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp">

    <EditText
        android:id="@+id/etAgentSearch"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:hint="🔍 Search agent name or ID"
        android:textSize="13sp"
        android:textColorHint="@color/theme_text_secondary"
        android:background="@drawable/bg_search_bar"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="text"
        android:maxLines="1"
        android:imeOptions="actionDone"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/layoutAgentCheckboxes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/tvAgentNoResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="কোনো agent পাওয়া যায়নি"
        android:textSize="12sp"
        android:textColor="@color/theme_text_secondary"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- Two bottom buttons: Select All/Clear All toggle + Apply -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnAgentSelectClearAll"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Select All"
            android:textSize="13sp"
            android:textColor="@color/theme_purple"
            style="?attr/borderlessButtonStyle"
            android:background="@drawable/bg_filter_chip_inactive" />

        <Button
            android:id="@+id/btnAgentApply"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Apply"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_filter_chip_active" />
    </LinearLayout>
</LinearLayout>
