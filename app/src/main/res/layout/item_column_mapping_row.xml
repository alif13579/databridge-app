<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp">

    <!-- Required badge -->
    <TextView
        android:id="@+id/tvRequired"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="*"
        android:textSize="14sp"
        android:textColor="@color/theme_red"
        android:layout_marginEnd="4dp" />

    <!-- Field name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFieldName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_primary" />

        <TextView
            android:id="@+id/tvFieldDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/theme_text_secondary" />
    </LinearLayout>

    <!-- Column selector (Manual mode) -->
    <Spinner
        android:id="@+id/spinnerColumn"
        android:layout_width="80dp"
        android:layout_height="36dp"
        android:spinnerMode="dropdown" />

    <!-- Header selector (Auto mode) -->
    <Spinner
        android:id="@+id/spinnerHeader"
        android:layout_width="130dp"
        android:layout_height="36dp"
        android:spinnerMode="dropdown"
        android:visibility="gone" />

</LinearLayout>
