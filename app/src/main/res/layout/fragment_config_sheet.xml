<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sheetRootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">
        <LinearLayout
            android:id="@+id/branchListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <ScrollView
        android:id="@+id/connectFlowLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView android:id="@+id/btnConnectCancel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="←" android:textSize="20sp" android:textColor="#6B7280"
                    android:padding="4dp" android:clickable="true" android:focusable="true"
                    android:layout_marginEnd="8dp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Connect Sheet" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView android:id="@+id/tvConnectBranchName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="11sp" android:textColor="#9CA3AF" />
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sheet ID (URL বা ID)" android:textSize="11sp" android:textColor="#9CA3AF"
                android:textStyle="bold" android:layout_marginBottom="4dp" />
            <EditText android:id="@+id/etSheetId" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="1BxiMVs0XRA..."
                android:padding="9dp" android:background="@drawable/bg_input_rounded"
                android:textSize="13sp" android:inputType="text" android:layout_marginBottom="10dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sheet নাম" android:textSize="11sp" android:textColor="#9CA3AF"
                android:textStyle="bold" android:layout_marginBottom="4dp" />
            <EditText android:id="@+id/etSheetName" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Delivery Agents June 2025"
                android:padding="9dp" android:background="@drawable/bg_input_rounded"
                android:textSize="13sp" android:inputType="text" android:layout_marginBottom="10dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tab নাম" android:textSize="11sp" android:textColor="#9CA3AF"
                android:textStyle="bold" android:layout_marginBottom="4dp" />
            <EditText android:id="@+id/etSheetTabName" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Sheet1"
                android:padding="9dp" android:background="@drawable/bg_input_rounded"
                android:textSize="13sp" android:inputType="text" android:layout_marginBottom="10dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Columns (comma separated: A, B, C)" android:textSize="11sp"
                android:textColor="#9CA3AF" android:textStyle="bold" android:layout_marginBottom="4dp" />
            <EditText android:id="@+id/etSheetColumns" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="A, B, C, D"
                android:padding="9dp" android:background="@drawable/bg_input_rounded"
                android:textSize="13sp" android:inputType="text" android:layout_marginBottom="10dp" />

            <TextView android:id="@+id/tvConnectError" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="#EF4444" android:visibility="gone" android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btnConnectSave" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="Save"
                android:textSize="13sp" android:textStyle="bold"
                android:backgroundTint="#E8380D" android:textColor="#FFFFFF" />
        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:id="@+id/managePanelLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView android:id="@+id/btnManageBack"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="←" android:textSize="20sp" android:textColor="#6B7280"
                    android:padding="4dp" android:clickable="true" android:focusable="true"
                    android:layout_marginEnd="8dp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Manage Connection" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView android:id="@+id/tvManageBranchName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="11sp" android:textColor="#9CA3AF" />
                </LinearLayout>
            </LinearLayout>

            <TextView android:id="@+id/tvManageSheetInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="?attr/colorOnSurface" android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Column Mapping" android:textSize="11sp" android:textColor="#9CA3AF"
                android:textStyle="bold" android:layout_marginBottom="4dp" />
            <TextView android:id="@+id/tvColumnMappingInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="#374151" android:layout_marginBottom="16dp" />

            <Button android:id="@+id/btnReconnect" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="Reconnect"
                android:textStyle="bold" android:backgroundTint="#3B82F6"
                android:textColor="#fff" android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btnDisconnect" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="Disconnect"
                android:textStyle="bold" android:backgroundTint="#EF4444" android:textColor="#fff" />
        </LinearLayout>
    </ScrollView>

</FrameLayout>
