<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sheetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══ PANEL 1: Branch Select ═══ -->
    <ScrollView
        android:id="@+id/panelBranchSelect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Google Sheet সংযোগ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="4dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="শাখা বেছে নিয়ে Google Sheet connect বা manage করুন"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvBranchLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRANCH"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6B7280"
                android:layout_marginBottom="5dp" />
            <Spinner android:id="@+id/spinnerBranch"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input_rounded"
                android:padding="10dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvSingleBranch"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_rounded"
                android:padding="10dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:visibility="gone"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvBranchEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No branch assigned to this user."
                android:gravity="center"
                android:padding="18dp"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:background="@drawable/bg_card_rounded"
                android:visibility="gone"
                android:layout_marginBottom="14dp" />

            <LinearLayout android:id="@+id/cardConnInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <TextView android:id="@+id/tvConnInfoSheet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tvConnInfoTab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="2dp" />
                <TextView android:id="@+id/tvConnInfoCols"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <Button android:id="@+id/btnBranchAction"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="Connect করুন"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#E8380D"
                android:textColor="#FFFFFF"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══ PANEL 2: Connect Flow Wizard ═══ -->
    <ScrollView
        android:id="@+id/panelConnect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <View android:id="@+id/btnCancelConnect"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_input_rounded"
                    android:clickable="true"
                    android:focusable="true" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connect Sheet"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#111827" />
                    <TextView android:id="@+id/tvConnBranchSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#9CA3AF" />
                </LinearLayout>
            </LinearLayout>

            <!-- Step indicators -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View android:id="@+id/step1Dot"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="#FFF3F0" />
                    <TextView android:id="@+id/step1Lbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account"
                        android:textSize="9sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <View android:id="@+id/step1Line"
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#E5E7EB"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View android:id="@+id/step2Dot"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="#F3F4F6" />
                    <TextView android:id="@+id/step2Lbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sheet"
                        android:textSize="9sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <View android:id="@+id/step2Line"
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#E5E7EB"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View android:id="@+id/step3Dot"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="#F3F4F6" />
                    <TextView android:id="@+id/step3Lbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tab"
                        android:textSize="9sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <View android:id="@+id/step3Line"
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#E5E7EB"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View android:id="@+id/step4Dot"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="#F3F4F6" />
                    <TextView android:id="@+id/step4Lbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Columns"
                        android:textSize="9sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Step 1: Google Account picker ── -->
            <LinearLayout android:id="@+id/stepView1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GOOGLE ACCOUNT"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="8dp" />

                <LinearLayout android:id="@+id/cardSelectedAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone">

                    <TextView android:id="@+id/tvSelectedAccountName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111827" />
                    <TextView android:id="@+id/tvSelectedAccountEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Button android:id="@+id/btnPickAccount"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="🔐 Google দিয়ে Sign in"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#374151" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="আপনি কোনো একটি Google account select করুন"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- ── Step 2: Sheet picker (Spinner) ── -->
            <LinearLayout android:id="@+id/stepView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GOOGLE SHEET"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="5dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <Spinner android:id="@+id/spinnerSheet"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="10dp" />
                    <ProgressBar android:id="@+id/pbSheetLoad"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="আপনার Google Drive এর spreadsheet গুলো লিস্ট হবে"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- ── Step 3: Tab picker (Spinner) ── -->
            <LinearLayout android:id="@+id/stepView3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHEET TAB"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="5dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <Spinner android:id="@+id/spinnerTab"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="10dp" />
                    <ProgressBar android:id="@+id/pbTabLoad"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="নির্বাচিত Sheet এর tab গুলো"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- ── Step 4: Column Range + Summary ── -->
            <LinearLayout android:id="@+id/stepView4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COLUMN RANGE (1–26)"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="5dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="শুরু (1=A, 2=B...)"
                            android:textSize="10sp"
                            android:textColor="#9CA3AF"
                            android:layout_marginBottom="4dp" />
                        <EditText android:id="@+id/etColStart"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:background="@drawable/bg_input_rounded"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:inputType="number" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="শেষ"
                            android:textSize="10sp"
                            android:textColor="#9CA3AF"
                            android:layout_marginBottom="4dp" />
                        <EditText android:id="@+id/etColEnd"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="10"
                            android:background="@drawable/bg_input_rounded"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:inputType="number" />
                    </LinearLayout>
                </LinearLayout>

                <TextView android:id="@+id/tvColPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp" />

                <TextView android:id="@+id/tvSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#166534"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Error -->
            <TextView android:id="@+id/tvConnectError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#EF4444"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Nav buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button android:id="@+id/btnStepBack"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="← Back"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#F3F4F6"
                    android:textColor="#374151"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone" />

                <Button android:id="@+id/btnStepNext"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Next →"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#E8380D"
                    android:textColor="#FFFFFF" />

                <Button android:id="@+id/btnStepConnect"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="✅ Connect"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#16A34A"
                    android:textColor="#FFFFFF"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══ PANEL 3: Manage ═══ -->
    <ScrollView android:id="@+id/panelManage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <View android:id="@+id/btnManBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_input_rounded"
                    android:clickable="true"
                    android:focusable="true" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Sheet"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#111827" />
                    <TextView android:id="@+id/tvManageBranchInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#9CA3AF" />
                </LinearLayout>
            </LinearLayout>

            <!-- Mini tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tabOverview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overview"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#E8380D"
                        android:padding="8dp" />
                    <View android:id="@+id/indOverview"
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#E8380D" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tabColumns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Columns"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280"
                        android:padding="8dp" />
                    <View android:id="@+id/indColumns"
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#E8380D"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tabSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sync"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280"
                        android:padding="8dp" />
                    <View android:id="@+id/indSync"
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#E8380D"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <!-- Overview card -->
            <LinearLayout android:id="@+id/cardOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄 SHEET"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280" />
                <TextView android:id="@+id/tvOvSheet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#111827"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📑 TAB"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280" />
                <TextView android:id="@+id/tvOvTab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#111827"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 COLUMNS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280" />
                <TextView android:id="@+id/tvOvCols"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#111827"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnManReconnect"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="🔄 Reconnect"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:backgroundTint="#3B82F6"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="6dp" />
                    <Button android:id="@+id/btnManDisconnect"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="🗑 Disconnect"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:backgroundTint="#EF4444"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Columns card -->
            <LinearLayout android:id="@+id/cardColumns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Column Mapping"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="10dp" />
                <TextView android:id="@+id/tvColPreviewMgr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="12dp" />
                <Button android:id="@+id/btnColChange"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="✏ Range পরিবর্তন"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="#3B82F6"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Sync card -->
            <LinearLayout android:id="@+id/cardSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄 Sync Status"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111827" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-sync: প্রতি 30 মিনিট"
                        android:textSize="12sp"
                        android:textColor="#6B7280" />
                </LinearLayout>
                <Button android:id="@+id/btnSyncNow"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="🔄 Sync এখনই করুন"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#E8380D"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
