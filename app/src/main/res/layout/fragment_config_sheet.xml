<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/theme_bg_app">

    <!-- Branch selector -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="10dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/theme_border">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@color/theme_bg_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRANCH"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerBranch"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@color/theme_bg_inner"
                android:padding="10dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Sheet connection status card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSheetStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="10dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/theme_border">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@color/theme_bg_card">

            <!-- Not connected state -->
            <LinearLayout
                android:id="@+id/layoutNotConnected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google Sheet"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No sheet connected for this branch"
                        android:textSize="12sp"
                        android:textColor="@color/theme_text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Connect"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_btn_accent_text"
                    android:backgroundTint="@color/theme_btn_accent_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />
            </LinearLayout>

            <!-- Connected state -->
            <LinearLayout
                android:id="@+id/layoutConnected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/circle_green"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Connected"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/theme_green" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvSheetName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sheet name"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/theme_text_primary"
                            android:layout_marginTop="2dp" />
                        <TextView
                            android:id="@+id/tvSheetMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tab · Columns · Last synced"
                            android:textSize="11sp"
                            android:textColor="@color/theme_text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnReconnect"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Edit"
                            android:textSize="11sp"
                            android:textColor="@color/theme_text_primary"
                            android:backgroundTint="@color/theme_bg_inner"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:layout_marginEnd="6dp" />

                        <Button
                            android:id="@+id/btnDisconnect"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Disconnect"
                            android:textSize="11sp"
                            android:textColor="@color/theme_red"
                            android:backgroundTint="@color/theme_bg_red"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Sync row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/theme_bg_inner"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Auto-sync interval"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/theme_text_primary" />
                        <TextView
                            android:id="@+id/tvLastSync"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last sync: Never"
                            android:textSize="11sp"
                            android:textColor="@color/theme_text_secondary" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinnerSyncInterval"
                        android:layout_width="120dp"
                        android:layout_height="36dp"
                        android:spinnerMode="dropdown"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnSyncNow"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Sync Now"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_btn_accent_text"
                        android:backgroundTint="@color/theme_btn_accent_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Column mapping card (visible when connected) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMapping"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        app:cardElevation="2dp"
        app:cardCornerRadius="10dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/theme_border">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/theme_bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Column Mapping"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_text_primary" />

                <!-- Mode toggle -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:orientation="horizontal"
                    android:background="@color/theme_bg_inner"
                    android:padding="3dp">

                    <TextView
                        android:id="@+id/tabModeManual"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Manual"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/theme_btn_accent_text"
                        android:background="@color/theme_btn_accent_bg" />

                    <TextView
                        android:id="@+id/tabModeAuto"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Auto-detect"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/theme_text_secondary"
                        android:background="@android:color/transparent" />
                </LinearLayout>
            </LinearLayout>

            <!-- Auto-detect button (visible in auto mode) -->
            <LinearLayout
                android:id="@+id/layoutAutoDetect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fetch headers from sheet"
                    android:textSize="12sp"
                    android:textColor="@color/theme_text_secondary" />

                <Button
                    android:id="@+id/btnDetectHeaders"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Detect Headers"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_btn_accent_text"
                    android:backgroundTint="@color/theme_btn_accent_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/theme_divider" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvColumnMapping"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
