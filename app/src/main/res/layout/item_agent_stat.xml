<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Rank -->
    <TextView
        android:id="@+id/tvAgentRank"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:text="#1"
        android:textSize="10sp"
        android:textColor="#334155"
        android:fontFamily="monospace"
        android:gravity="end" />

    <!-- Name + Run -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/tvAgentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agent Name"
            android:textSize="12sp"
            android:textColor="#F1F5F9"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvAgentRunId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R-XXXXXX"
            android:textSize="10sp"
            android:textColor="#334155"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Stats -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/tvAgentDelivered"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0✓"
            android:textSize="11sp"
            android:textColor="#10B981"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvAgentReturned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0↩"
            android:textSize="11sp"
            android:textColor="#EF4444"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvAgentOnHold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0⏸"
            android:textSize="11sp"
            android:textColor="#F59E0B"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Rate -->
    <TextView
        android:id="@+id/tvAgentRate"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textSize="11sp"
        android:textColor="#10B981"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="end" />

</LinearLayout>
