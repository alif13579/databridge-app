<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/bg_memory_card"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Date row -->
    <TextView
        android:id="@+id/tvMemoryDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12 Jan, 10:00 AM"
        android:textColor="@color/theme_text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.03"
        android:layout_marginBottom="4dp"/>

    <!-- Counts -->
    <TextView
        android:id="@+id/tvMemoryCounts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parcel: 10, Doc: 5"
        android:textColor="@color/theme_text_primary"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"/>

    <!-- Earnings + Actions row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <!-- Earnings amount — prominent -->
        <TextView
            android:id="@+id/tvMemoryEarnings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="৳500"
            android:textColor="@color/theme_text_accent"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <!-- Edit button — 44dp, oval accent bg, ripple -->
        <ImageButton
            android:id="@+id/btnEditMemory"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_btn_edit_memory"
            android:padding="10dp"
            android:src="@drawable/ic_edit_mem"
            android:contentDescription="Edit entry"
            android:layout_marginStart="4dp"
            app:tint="@color/theme_text_accent"/>

        <!-- Delete button — 44dp, oval red bg, ripple -->
        <ImageButton
            android:id="@+id/btnDeleteMemory"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_btn_delete_memory"
            android:padding="10dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_delete_mem"
            android:contentDescription="Delete entry"
            app:tint="#EF4444"/>

    </LinearLayout>
</LinearLayout>
