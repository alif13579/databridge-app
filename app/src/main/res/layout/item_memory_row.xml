<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_memory_card"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvMemoryDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12 Jan, 10:00 AM"
        android:textColor="@color/theme_text_primary"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/tvMemoryCounts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parcel: 10, Doc: 5"
        android:textColor="@color/theme_text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">
        <TextView
            android:id="@+id/tvMemoryEarnings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="৳500"
            android:textColor="@color/theme_text_primary"
            android:textSize="14sp"/>
        <ImageButton
            android:id="@+id/btnEditMemory"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/theme_text_primary"/>
        <ImageButton
            android:id="@+id/btnDeleteMemory"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#ff6666"/>
    </LinearLayout>

</LinearLayout>
