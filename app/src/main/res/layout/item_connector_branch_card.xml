<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootConnectorBranchCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/theme_bg_card"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvConnectorBranchName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Branch name"
            android:textColor="@color/theme_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvConnectorCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No connectors"
            android:textColor="@color/theme_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnManageConnector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manage"
        android:textAllCaps="false"
        android:textSize="12sp"
        style="?attr/borderlessButtonStyle"/>

</LinearLayout>
