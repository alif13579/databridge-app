<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- ── Top bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="?attr/colorSurface"
        android:elevation="3dp">

        <TextView
            android:id="@+id/btnPdBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="20sp"
            android:gravity="center"
            android:textColor="@color/theme_text_primary"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tvPdParcelId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CON001"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_primary"
            android:layout_marginStart="4dp" />

        <ProgressBar
            android:id="@+id/pdProgressBar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── Scrollable body ──────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- ── Parcel Info Card ────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_parcel_card"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <!-- Status + COD row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tvPdStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:includeFontPadding="false" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvPdCod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="৳850"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_accent"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <!-- Customer name -->
                <TextView
                    android:id="@+id/tvPdCustomer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rahim Uddin"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_text_primary"
                    android:includeFontPadding="false"
                    android:layout_marginBottom="6dp" />

                <!-- ID + Phone -->
                <TextView
                    android:id="@+id/tvPdMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CON001 · 01711223344"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_accent"
                    android:includeFontPadding="false"
                    android:layout_marginBottom="5dp" />

                <!-- Address -->
                <TextView
                    android:id="@+id/tvPdAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Fatullah, Narayanganj"
                    android:textSize="12sp"
                    android:textColor="@color/theme_text_secondary"
                    android:includeFontPadding="false"
                    android:layout_marginBottom="5dp" />

                <!-- Hub -->
                <TextView
                    android:id="@+id/tvPdHub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏢 Sonargaon Hub"
                    android:textSize="12sp"
                    android:textColor="@color/theme_text_secondary"
                    android:includeFontPadding="false"
                    android:layout_marginBottom="5dp" />

                <!-- Dates -->
                <TextView
                    android:id="@+id/tvPdDates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Created: 12 Jul 2026"
                    android:textSize="11sp"
                    android:textColor="@color/theme_text_muted"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- ── Journey Log section ────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Journey Log"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_text_primary" />

                <TextView
                    android:id="@+id/tvPdRemarksCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 entries"
                    android:textSize="11sp"
                    android:textColor="@color/theme_text_muted" />
            </LinearLayout>

            <!-- Remarks empty state -->
            <TextView
                android:id="@+id/tvPdRemarksEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📭  No remarks yet"
                android:textSize="13sp"
                android:gravity="center"
                android:textColor="@color/theme_text_muted"
                android:padding="24dp"
                android:visibility="gone" />

            <!-- Timeline entries go here -->
            <LinearLayout
                android:id="@+id/layoutPdTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
