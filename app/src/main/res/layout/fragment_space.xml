<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070d1a">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0d1627"
                android:padding="16dp"
                android:paddingBottom="12dp">

                <!-- Top row: avatar + name + COD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Avatar circle -->
                        <TextView
                            android:id="@+id/twAvatarIcon"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_avatar_gradient"
                            android:gravity="center"
                            android:text="📦"
                            android:textSize="16dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:id="@+id/twRoleLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DELIVERY AGENT"
                                android:textSize="12sp"
                                android:textColor="#00d4e8"
                                android:textStyle="bold"
                                android:letterSpacing="1" />

                            <TextView
                                android:id="@+id/twAgentInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sonia Akter · Sonargaon Hub"
                                android:textSize="11sp"
                                android:textColor="#64748b"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's COD"
                            android:textSize="11sp"
                            android:textColor="#64748b" />

                        <TextView
                            android:id="@+id/twTodayCod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳0"
                            android:textSize="18sp"
                            android:textColor="#00d4e8"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Stats grid: 3 columns -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:gravity="center">

                    <LinearLayout
                        android:id="@+id/layoutStatTotal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="#0a1220"
                        android:layout_marginEnd="5dp">

                        <TextView
                            android:id="@+id/twStatTotalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="#e2e8f0"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total"
                            android:textSize="11sp"
                            android:textColor="#64748b"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutStatConfirmed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="#0a1220"
                        android:layout_marginEnd="5dp">

                        <TextView
                            android:id="@+id/twStatConfirmedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="#10b981"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Confirmed"
                            android:textSize="11sp"
                            android:textColor="#64748b"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutStatPending"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="#0a1220">

                        <TextView
                            android:id="@+id/twStatPendingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="#f59e0b"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textSize="11sp"
                            android:textColor="#64748b"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Search Bar -->
                <LinearLayout
                    android:id="@+id/layoutSearchBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#0a1220"
                    android:padding="10dp"
                    android:layout_marginTop="14dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="15sp"
                        android:alpha="0.5" />

                    <EditText
                        android:id="@+id/twSearchInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        
                        android:hint="Search by phone or consignment ID..."
                        android:textColorHint="#64748b"
                        android:textColor="#e2e8f0"
                        android:textSize="13sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:inputType="text"
                        android:maxLines="1"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/twSearchClear"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="✕"
                        android:textSize="11sp"
                        android:textColor="#64748b"
                        android:gravity="center"
                        android:visibility="gone"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                <!-- Search result count -->
                <TextView
                    android:id="@+id/twSearchCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#64748b"
                    android:layout_marginTop="6dp"
                    android:paddingStart="2dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Filter Tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0d1627"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutFilterTabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </HorizontalScrollView>

            <!-- Parcel List Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false">

                <ProgressBar
                    android:id="@+id/twProgressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/twEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="📭\n\nNo parcels found"
                    android:textSize="14sp"
                    android:textColor="#64748b"
                    android:padding="40dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutParcelList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
