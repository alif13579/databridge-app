<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scannerSheetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══ PANEL 1: Branch Select ═══ -->
    <ScrollView
        android:id="@+id/panelBranchSelect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scanner Sheet সংযোগ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="4dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="শাখা বেছে নিয়ে scan-এর জন্য Google Sheet connect বা manage করুন"
                android:textSize="12sp"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginBottom="16dp" />

            <!-- No branch assigned -->
            <TextView
                android:id="@+id/tvScBranchEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No branch assigned to this user."
                android:gravity="center"
                android:padding="18dp"
                android:textColor="@color/theme_text_muted"
                android:textSize="13sp"
                android:background="@drawable/bg_card_rounded"
                android:visibility="gone"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvScBranchLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRANCH"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginBottom="5dp" />

            <Spinner android:id="@+id/spinnerScBranch"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input_rounded"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <!-- Existing connections for the selected branch — rows injected programmatically -->
            <TextView
                android:id="@+id/tvScConnectionsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECTIONS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/containerScConnections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvScNoConnections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="এই শাখার জন্য এখনো কোনো Scanner Sheet connect করা হয়নি।"
                android:gravity="center"
                android:padding="16dp"
                android:textColor="@color/theme_text_muted"
                android:textSize="12sp"
                android:background="@drawable/bg_card_rounded"
                android:layout_marginBottom="14dp"
                android:visibility="gone" />

            <Button android:id="@+id/btnScAddConnection"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="+ নতুন Sheet Connect করুন"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#E8380D"
                android:textColor="@color/theme_bg_card" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══ PANEL 2: Connect Flow Wizard (4 steps — no mapping step) ═══ -->
    <ScrollView
        android:id="@+id/panelScConnect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <View android:id="@+id/btnScCancelConnect"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_input_rounded"
                    android:clickable="true"
                    android:focusable="true" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connect Scanner Sheet"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_text_primary" />
                    <TextView android:id="@+id/tvScConnBranchSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/theme_text_muted" />
                </LinearLayout>
            </LinearLayout>

            <!-- Step indicators (4 steps — Account, Sheet, Tab, Columns) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/scStep1Dot" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/theme_bg_card" />
                    <TextView android:id="@+id/scStep1Lbl" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Account" android:textSize="9sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <View android:id="@+id/scStep1Line" android:layout_width="0dp" android:layout_height="2dp"
                    android:layout_weight="1" android:background="@color/theme_border" android:layout_marginBottom="14dp" />

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/scStep2Dot" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/theme_bg_card" />
                    <TextView android:id="@+id/scStep2Lbl" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sheet" android:textSize="9sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <View android:id="@+id/scStep2Line" android:layout_width="0dp" android:layout_height="2dp"
                    android:layout_weight="1" android:background="@color/theme_border" android:layout_marginBottom="14dp" />

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/scStep3Dot" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/theme_bg_card" />
                    <TextView android:id="@+id/scStep3Lbl" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tab" android:textSize="9sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <View android:id="@+id/scStep3Line" android:layout_width="0dp" android:layout_height="2dp"
                    android:layout_weight="1" android:background="@color/theme_border" android:layout_marginBottom="14dp" />

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/scStep4Dot" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/theme_bg_card" />
                    <TextView android:id="@+id/scStep4Lbl" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Columns" android:textSize="9sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Step 1: Google Account picker ── -->
            <LinearLayout android:id="@+id/scStepView1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="GOOGLE ACCOUNT" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/theme_text_secondary" android:layout_marginBottom="8dp" />

                <LinearLayout android:id="@+id/scCardSelectedAccount"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card_rounded"
                    android:padding="14dp" android:layout_marginBottom="10dp" android:visibility="gone">
                    <TextView android:id="@+id/tvScSelectedAccountName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="@color/theme_text_primary" />
                    <TextView android:id="@+id/tvScSelectedAccountEmail"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="@color/theme_text_secondary" android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_card_rounded" android:clickable="true"
                    android:focusable="true" android:id="@+id/btnScPickAccount"
                    android:elevation="2dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_marginStart="14dp" android:src="@drawable/ic_google" android:scaleType="fitCenter" />
                    <TextView android:id="@+id/tvScPickAccountLabel"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Sign in with Google"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/theme_text_primary"
                        android:gravity="center" android:fontFamily="sans-serif-medium" />
                    <View android:layout_width="22dp" android:layout_height="22dp" android:layout_marginEnd="14dp" />
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="আপনি কোনো একটি Google account select করুন"
                    android:textSize="11sp" android:textColor="@color/theme_text_muted" android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- ── Step 2: Sheet picker ── -->
            <LinearLayout android:id="@+id/scStepView2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="GOOGLE SHEET" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/theme_text_secondary" android:layout_marginBottom="5dp" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:id="@+id/tvScSelectedSheet"
                        android:layout_width="match_parent" android:layout_height="46dp"
                        android:background="@drawable/bg_input_rounded" android:padding="10dp"
                        android:gravity="center_vertical" android:text="— Sheet বেছে নিন —"
                        android:textSize="13sp" android:textColor="@color/theme_text_secondary"
                        android:clickable="true" android:focusable="true" />
                    <ProgressBar android:id="@+id/pbScSheetLoad"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp" android:visibility="gone" />
                </FrameLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="আপনার Google Drive এর spreadsheet গুলো লিস্ট হবে"
                    android:textSize="11sp" android:textColor="@color/theme_text_muted" android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- ── Step 3: Tab pattern + Nickname ── -->
            <LinearLayout android:id="@+id/scStepView3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CONNECTION NICKNAME" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/theme_text_secondary" android:layout_marginBottom="5dp" />
                <EditText android:id="@+id/etScNickname"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:background="@drawable/bg_input_rounded"
                    android:padding="10dp" android:textSize="13sp"
                    android:hint="যেমন: Delivery Scan Sheet"
                    android:inputType="text" android:maxLines="1"
                    android:layout_marginBottom="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TAB NAME PATTERN" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/theme_text_secondary" android:layout_marginBottom="5dp" />
                <EditText android:id="@+id/etScTabPattern"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:background="@drawable/bg_input_rounded"
                    android:padding="10dp" android:textSize="13sp"
                    android:text="Day {dd}"
                    android:inputType="text" android:maxLines="1"
                    android:layout_marginBottom="8dp" />

                <TextView android:id="@+id/tvScTabPreview"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/theme_text_secondary"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="10dp" android:layout_marginBottom="6dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="{dd} প্রতিদিনের তারিখ দিয়ে automatically replace হবে — আজকের tab হবে উপরে দেখানো নামে"
                    android:textSize="11sp" android:textColor="@color/theme_text_muted" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- ── Step 4: Match Column + Write Column ── -->
            <LinearLayout android:id="@+id/scStepView4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MATCH COLUMN (Employee ID)" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/theme_text_secondary" android:layout_marginBottom="5dp" />
                <EditText android:id="@+id/etScMatchColumn"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:background="@drawable/bg_input_rounded"
                    android:padding="10dp" android:textSize="14sp" android:gravity="center"
                    android:hint="যেমন: T (Column 20)"
                    android:inputType="textCapCharacters" android:maxLines="1"
                    android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="যে column-এ agent-এর Employee ID খুঁজে match করা হবে"
                    android:textSize="11sp" android:textColor="@color/theme_text_muted" android:layout_marginBottom="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WRITE COLUMN (Scan Data)" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/theme_text_secondary" android:layout_marginBottom="5dp" />
                <EditText android:id="@+id/etScWriteColumn"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:background="@drawable/bg_input_rounded"
                    android:padding="10dp" android:textSize="14sp" android:gravity="center"
                    android:hint="যেমন: K (Column 11)"
                    android:inputType="textCapCharacters" android:maxLines="1"
                    android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Match পাওয়া row-এর blank cell-এ scan করা data এখানে বসবে"
                    android:textSize="11sp" android:textColor="@color/theme_text_muted" android:layout_marginBottom="16dp" />

                <TextView android:id="@+id/tvScSummary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#166534"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp" android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Error -->
            <TextView android:id="@+id/tvScConnectError"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#EF4444"
                android:layout_marginTop="8dp" android:visibility="gone" />

            <!-- Nav buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="16dp">

                <Button android:id="@+id/btnScStepBack"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="← Back" android:textSize="13sp" android:textStyle="bold"
                    android:backgroundTint="@color/theme_bg_inner" android:textColor="@color/theme_text_primary"
                    android:layout_marginEnd="6dp" android:visibility="gone" />

                <Button android:id="@+id/btnScStepNext"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Next →" android:textSize="13sp" android:textStyle="bold"
                    android:backgroundTint="#E8380D" android:textColor="@color/theme_bg_card"
                    android:visibility="gone" />

                <Button android:id="@+id/btnScStepConnect"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="✅ Connect" android:textSize="13sp" android:textStyle="bold"
                    android:backgroundTint="#16A34A" android:textColor="@color/theme_bg_card"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
