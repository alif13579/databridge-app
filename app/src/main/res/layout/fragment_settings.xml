<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 🔹 Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="️ Settings"
            android:textColor="@color/theme_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!--  AUTO ACTIONS Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTO ACTIONS"
            android:textColor="@color/theme_text_accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Switch 1: Auto open dialer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto open dialer"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number এলে dialer auto খুলবে"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switchAutoDialer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/theme_text_accent"
                android:trackTint="#555555" />
        </LinearLayout>

        <!-- Switch 2: Auto dial -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto dial"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dialer খুলে auto call শুরু"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switchAutoDial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/theme_text_accent"
                android:trackTint="#555555" />
        </LinearLayout>

        <!-- Switch: Automatic WhatsApp Sender -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Automatic WhatsApp Sender"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="16sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remark save হলে WhatsApp message খুলবে (agent-এর এক tap লাগবে)"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <Switch
                    android:id="@+id/switchWhatsAppSender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/theme_text_accent"
                    android:trackTint="#555555" />
            </LinearLayout>

            <!-- Template editor — visible only when toggle is ON -->
            <LinearLayout
                android:id="@+id/layoutWhatsAppTemplate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message Template"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Variables: {customer_name}, {parcel_value}, {address}, {consignment_id}, {agent_phone}"
                    android:textSize="11sp"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/etWhatsAppTemplate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_rounded"
                    android:padding="12dp"
                    android:textSize="13sp"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:maxLines="8"
                    android:gravity="top"
                    android:layout_marginBottom="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">
                    <Button
                        android:id="@+id/btnWhatsAppTemplateReset"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Reset"
                        android:textSize="12sp"
                        android:textColor="@color/theme_text_secondary"
                        android:backgroundTint="@color/theme_bg_card"
                        android:layout_marginEnd="8dp" />
                    <Button
                        android:id="@+id/btnWhatsAppTemplateSave"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Save"
                        android:textSize="12sp"
                        android:textColor="@color/theme_bg_card"
                        android:backgroundTint="#16A34A" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Switch 3: Auto copy to clipboard -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto copy to clipboard"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Incoming text/number clipboard-এ save হবে"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switchAutoCopy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/theme_text_accent"
                android:trackTint="#555555" />
        </LinearLayout>

        <!--  NOTIFICATIONS Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOTIFICATIONS"
            android:textColor="@color/theme_text_accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Switch 3: Incoming alert -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Incoming alert"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="নতুন data এলে notification"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switchIncomingAlert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/theme_text_accent"
                android:trackTint="#555555" />
        </LinearLayout>

        <!-- Switch 4: Sound on receive -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sound on receive"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data receive হলে sound"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <Switch
                android:id="@+id/switchSound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/theme_text_accent"
                android:trackTint="#555555" />
        </LinearLayout>

        <!--  ACCOUNT Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textColor="@color/theme_text_accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Login / Register Row -->
        <LinearLayout
            android:id="@+id/layoutLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/theme_bg_card"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvLoginStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login / Register"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tvLoginSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data cloud এ save করতে Login"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Login Spinner -->
            <ProgressBar
                android:id="@+id/pbLogin"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="@color/theme_text_accent"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/theme_text_accent"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Clear Local History Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear local history"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device থেকে সব data মুছবে"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Clear Button + Spinner -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <Button
                    android:id="@+id/btnClearHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear"
                    android:backgroundTint="#ff4444"
                    android:textColor="#ffffff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:padding="12dp" />
                <ProgressBar
                    android:id="@+id/pbClearHistory"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="#ff4444"
                    android:visibility="gone"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- App Version -->
        <TextView
            android:id="@+id/tvAppVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v2.0 • DataBridge"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>