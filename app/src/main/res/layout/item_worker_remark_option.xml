<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_remark_opt_inactive"
    android:padding="12dp"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/twRemarkOptIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginEnd="10dp"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/twRemarkOptText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Customer কে parcel delivery করা হচ্ছে"
        android:textSize="12sp"
        android:textColor="@color/theme_text_remark_opt"
        android:maxLines="2"
        android:ellipsize="end"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/twRemarkOptAutoTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="→CONFIRMED"
        android:textSize="9sp"
        android:textColor="@color/theme_purple"
        android:textStyle="bold"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:background="@color/theme_bg_validation"
        android:layout_marginStart="8dp"
        android:includeFontPadding="false"
        android:visibility="gone" />

    <View
        android:id="@+id/viewRemarkOptSelected"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_selected_dot"
        android:layout_marginStart="8dp"
        android:visibility="gone" />

</LinearLayout>
