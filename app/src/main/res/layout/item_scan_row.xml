<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:background="#1A1A2E"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvScanIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="📷"
        android:textSize="18sp"
        android:background="#15202b" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvScanCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CODE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvScanMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="time • Scanned"
            android:textSize="11sp"
            android:textColor="#555555"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnEditScan"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="✏️ Edit"
        android:textSize="10sp"
        android:textColor="#ffd200"
        android:background="@drawable/btn_edit_scan"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginEnd="6dp" />

    <Button
        android:id="@+id/btnDeleteScan"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="🗑️ Delete"
        android:textSize="10sp"
        android:textColor="#ff5050"
        android:background="@drawable/btn_delete_scan"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

</LinearLayout>
