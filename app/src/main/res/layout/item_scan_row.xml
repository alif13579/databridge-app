<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_scan_row_card"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvScanIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="📷"
        android:textSize="18sp"
        android:background="@drawable/bg_scan_icon" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvScanCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CODE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_primary"
            android:maxLines="3"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvScanMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="time • Scanned"
            android:textSize="11sp"
            android:textColor="@color/theme_text_secondary"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvScanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pending"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:background="@drawable/bg_scan_status_badge"
        android:layout_marginEnd="6dp" />

    <ImageButton
        android:id="@+id/btnScanMenu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_more"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:contentDescription="More options"
        app:tint="@color/theme_text_secondary" />

</LinearLayout>
