<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:background="@color/theme_bg_card"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvScanIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="📷"
        android:textSize="18sp"
        android:background="@color/theme_bg_inner" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvScanCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CODE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvScanMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="time • Scanned"
            android:textSize="11sp"
            android:textColor="@color/theme_text_secondary"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnEditScan"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_edit_24"
        android:background="@drawable/btn_edit_scan"
        android:padding="6dp"
        android:layout_marginEnd="6dp"
        android:contentDescription="Edit"
        app:tint="@color/theme_yellow" />

    <ImageButton
        android:id="@+id/btnDeleteScan"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_delete_24"
        android:background="@drawable/btn_delete_scan"
        android:padding="6dp"
        android:contentDescription="Delete"
        app:tint="@color/theme_red" />

</LinearLayout>
