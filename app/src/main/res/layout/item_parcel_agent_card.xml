<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <!-- Age badge — fixed to top-right corner regardless of card height -->
    <TextView
        android:id="@+id/tvAgtAge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:text="3D"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/theme_text_muted"
        android:background="@drawable/bg_age_badge"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:includeFontPadding="false"
        android:elevation="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_parcel_card"
        android:padding="12dp"
        android:paddingStart="18dp"
        android:paddingEnd="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAgtCustomer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rahim Mia"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />


            </LinearLayout>

            <TextView
                android:id="@+id/tvAgtMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DB-2201 · 01885580909"
                android:textSize="11sp"
                android:textColor="@color/theme_accent"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvAgtAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📍 House 12, Mograpara Bazar"
                    android:textSize="11sp"
                    android:textColor="@color/theme_text_secondary" />

                <TextView
                    android:id="@+id/tvAgtStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Confirmed"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Remark box (CC expected remark from worker) — chat-bubble style: text on top,
         elapsed time bottom-right, like a message timestamp -->
    <LinearLayout
        android:id="@+id/layoutAgtRemarksBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_remark_chip"
        android:padding="6dp"
        android:paddingStart="8dp"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvAgtRemarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💬 Customer want to receive today"
            android:textSize="11sp"
            android:textColor="@color/theme_text_secondary"
            android:maxLines="2"
            android:ellipsize="end"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tvAgtRemarksTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="🕐 2h 15m ago"
            android:textSize="9sp"
            android:textColor="@color/theme_text_muted"
            android:layout_marginTop="3dp"
            android:includeFontPadding="false"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Amount — bottom-right corner, always visible, far from the fixed age/attempt
         badge (top-right) so it never gets covered by it -->
    <TextView
        android:id="@+id/tvAgtCod"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="৳850"
        android:textSize="15sp"
        android:textColor="@color/theme_accent"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:includeFontPadding="false" />

    <!-- Action Buttons: Call + Remarks, full width equal split -->
    <LinearLayout
        android:id="@+id/layoutAgtActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="10dp"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btnAgtCall"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="📞 Call"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_inverse"
            android:gravity="center"
            android:background="@drawable/btn_call_green"
            android:layout_marginEnd="4dp"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/btnAgtSetRemarks"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="✏️ Set Remarks"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_inverse"
            android:gravity="center"
            android:background="@drawable/btn_action_cyan"
            android:includeFontPadding="false" />

    </LinearLayout>

    </LinearLayout>

    <!-- Rotating gradient ring — shown when someone has this parcel's card expanded
         (see EngagedStateManager). Must be the LAST child so it draws on top of everything
         else, including the age badge. -->
    <com.cloudx.databridge.EngagedRingView
        android:id="@+id/viewEngagedRing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
</FrameLayout>
