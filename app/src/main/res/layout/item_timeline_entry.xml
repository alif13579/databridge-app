<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start">

    <!-- Left side: dot + line -->
    <LinearLayout
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginEnd="12dp">

        <View
            android:id="@+id/viewTimelineDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_timeline_dot"
            android:layout_marginTop="3dp" />

        <View
            android:id="@+id/viewTimelineLine"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:minHeight="24dp"
            android:background="@color/theme_bg_timeline_line"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Right side: content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/twTimelineStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ASSIGNED"
            android:textSize="10sp"
            android:textColor="@color/theme_accent"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/twTimelineRemark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sonia Akter কে assign করা হয়েছে"
            android:textSize="12sp"
            android:textColor="@color/theme_text_primary"
            android:layout_marginTop="2dp"
            android:includeFontPadding="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/twTimelineMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9:00 AM · System"
            android:textSize="10sp"
            android:textColor="@color/theme_text_secondary"
            android:layout_marginTop="3dp"
            android:includeFontPadding="false" />
    </LinearLayout>

</LinearLayout>
