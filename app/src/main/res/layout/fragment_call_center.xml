<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header"
                android:padding="16dp"
                android:paddingBottom="12dp">

                <!-- Top row: avatar + name + Validation Queue -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/twCcaAvatarIcon"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_avatar_gradient_purple"
                            android:gravity="center"
                            android:text="🎯"
                            android:textSize="16dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:id="@+id/twCcaRoleLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CALL CENTER"
                                android:textSize="12sp"
                                android:textColor="@color/theme_purple"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/twCcaAgentInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Alif Mia · Supervisor"
                                android:textSize="11sp"
                                android:textColor="@color/theme_text_secondary"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Validation Queue"
                            android:textSize="11sp"
                            android:textColor="@color/theme_text_secondary" />

                        <TextView
                            android:id="@+id/twCcaValidationCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 pending"
                            android:textSize="18sp"
                            android:textColor="@color/theme_purple_light"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <Spinner
                            android:id="@+id/spinnerCcRunType"
                            android:layout_width="90dp"
                            android:layout_height="26dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_search_bar"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCcaCollapseArrow"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:layout_gravity="top"
                        android:text="▼"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:textColor="@color/theme_text_secondary"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                <!-- Search bar + Agent filter (always visible, independent of collapse state) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:id="@+id/layoutCcaSearchBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_search_bar"
                        android:padding="7dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍"
                            android:textSize="15sp"
                            android:alpha="0.5" />

                        <EditText
                            android:id="@+id/twCcaSearchInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Search phone, ID or COD..."
                            android:textColorHint="@color/theme_text_secondary"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="13sp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="text"
                            android:maxLines="1"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/twCcaSearchClear"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:text="✕"
                            android:textSize="11sp"
                            android:textColor="@color/theme_text_secondary"
                            android:gravity="center"
                            android:visibility="gone"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinnerCcaAgent"
                        android:layout_width="100dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_search_bar"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:spinnerMode="dropdown" />
                </LinearLayout>

                <!-- Search result count -->
                <TextView
                    android:id="@+id/twCcaSearchCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginTop="-4dp"
                    android:layout_marginBottom="6dp"
                    android:paddingStart="2dp"
                    android:visibility="gone" />

                <!-- Collapsible section: Auto Call, Stats, Access Mode, Branch chips —
                     collapsed by default so the header doesn't eat half the screen; the
                     arrow above toggles this. -->
                <LinearLayout
                    android:id="@+id/layoutCcaCollapsibleSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                <!-- Auto Call row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_stat_card"
                    android:padding="8dp"
                    android:paddingStart="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📞 Auto Call (Pending)"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_text_primary" />

                    <Button
                        android:id="@+id/btnCcAutoCallStartPause"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶ Start"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_bg_card"
                        android:backgroundTint="#7C3AED"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone" />

                    <Switch
                        android:id="@+id/switchCcAutoCall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/btnCcAutoCallGapMenu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="⋮"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:textColor="@color/theme_text_secondary"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                <!-- Stats grid: 4 columns -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:gravity="center">

                    <LinearLayout
                        android:id="@+id/layoutCcaStatTotal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_stat_card"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/twCcaStatTotalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textColor="@color/theme_text_primary"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total"
                            android:textSize="10sp"
                            android:textColor="@color/theme_text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutCcaStatConfirmed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_stat_card"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/twCcaStatConfirmedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textColor="@color/theme_green"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Confirmed"
                            android:textSize="10sp"
                            android:textColor="@color/theme_text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutCcaStatPending"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_stat_card"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/twCcaStatPendingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textColor="@color/theme_yellow"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textSize="10sp"
                            android:textColor="@color/theme_text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutCcaStatRejected"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_stat_card">

                        <TextView
                            android:id="@+id/twCcaStatRejectedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textColor="@color/theme_red"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rejected"
                            android:textSize="10sp"
                            android:textColor="@color/theme_text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Access Mode Toggle: Priority (verify_req only) vs All Agents (branch-wide) -->
                <LinearLayout
                    android:id="@+id/layoutCcaAccessMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/tvCcaModePriority"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:text="🔔 Priority Queue"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_filter_chip_active"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tvCcaModeAllAgents"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:gravity="center"
                        android:text="👥 All Agents"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_filter_chip_inactive"
                        android:textColor="@color/theme_text_secondary" />
                </LinearLayout>

                <!-- Branch Filter Chips (dynamic visibility) -->
                <HorizontalScrollView
                    android:id="@+id/layoutCcaBranchFilter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/layoutCcaBranchChips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                </LinearLayout>
                <!-- /layoutCcaCollapsibleSection -->
            </LinearLayout>

            <!-- Status Filter Tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutCcaFilterTabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </HorizontalScrollView>

            <!-- Pull-to-refresh + Parcel List Container — the RecyclerView is now the SOLE
                 scrolling element (fills remaining space below the fixed header/tabs), which
                 avoids the RecyclerView-in-ScrollView height-measurement race and
                 gives proper view recycling for smooth scroll on large lists. -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefreshCca"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false">

                <ProgressBar
                    android:id="@+id/twCcaProgressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/twCcaEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="📭\n\nNo parcels found"
                    android:textSize="14sp"
                    android:textColor="@color/theme_text_secondary"
                    android:padding="40dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCcaParcelList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />
            </FrameLayout>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

</FrameLayout>
