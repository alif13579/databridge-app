<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/theme_bg_app">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/theme_bg_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="0dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuration"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage app settings, remarks, statuses and sheet connections"
            android:textSize="12sp"
            android:textColor="@color/theme_text_secondary"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="12dp" />

        <!-- Tab bar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/llConfigTabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView
                        android:id="@+id/tabRemarks"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="💬 Remarks"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_text_primary" />
                    <View
                        android:id="@+id/indicatorRemarks"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@color/theme_accent" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView
                        android:id="@+id/tabLanguage"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="🌐 Language"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_text_secondary" />
                    <View
                        android:id="@+id/indicatorLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@color/theme_accent"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView
                        android:id="@+id/tabStatuses"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="🏷️ Statuses"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_text_secondary" />
                    <View
                        android:id="@+id/indicatorStatuses"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@color/theme_accent"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView
                        android:id="@+id/tabSheet"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="📊 Sheet"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_text_secondary" />
                    <View
                        android:id="@+id/indicatorSheet"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@color/theme_accent"
                        android:visibility="invisible" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:id="@+id/configContentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
