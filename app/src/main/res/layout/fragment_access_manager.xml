<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/theme_bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAccessTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Access Manager"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/theme_text_primary" />

            <TextView
                android:id="@+id/tvAccessSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create, rename, delete roles and set permissions"
                android:textSize="12sp"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnCreateRole"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_gravity="top|end">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_salary_add_circle"
                android:padding="10dp"
                android:src="@drawable/ic_add_24"
                android:tint="@color/theme_btn_accent_text"
                android:contentDescription="Create role" />
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="2dp"
        app:cardCornerRadius="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/theme_text_secondary">

        <LinearLayout
            android:id="@+id/llTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/theme_bg_card"
            android:paddingTop="6dp"
            android:paddingBottom="0dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tabRoles"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="🛡️ Roles"
                    android:textColor="@color/theme_text_primary"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/indicatorRoles"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="2dp"
                    android:background="@color/theme_accent" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tabUsers"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="👤 Users"
                    android:textColor="@color/theme_text_secondary"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/indicatorUsers"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="2dp"
                    android:background="@color/theme_accent"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardUserFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardUseCompatPadding="true"
        app:cardElevation="2dp"
        app:cardCornerRadius="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/theme_text_secondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter:"
                android:textSize="12sp"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinnerFilterRole"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.8"
                android:spinnerMode="dropdown"
                android:tooltipText="Filter by role" />

            <Space
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <EditText
                android:id="@+id/etFilterUser"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1.2"
                android:hint="Search user"
                android:singleLine="true"
                android:paddingStart="8dp"
                android:background="@color/theme_bg_card" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoleControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/theme_text_secondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:weightSum="1.2"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Role"
                android:textSize="12sp"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinnerRoles"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:spinnerMode="dropdown"
                android:tooltipText="Select role" />

            <FrameLayout
                android:id="@+id/btnRoleMenu"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:layout_marginStart="12dp"
                android:layout_gravity="end"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_salary_add_circle"
                    android:padding="10dp"
                    android:src="@drawable/ic_settings_24"
                    android:tint="@color/theme_btn_accent_text"
                    android:contentDescription="Role actions" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Hidden placeholders to keep listeners working for popup actions -->
    <FrameLayout
        android:id="@+id/btnRenameRole"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/btnDeleteRole"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Users Access button removed; Users managed via Users tab -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPermissions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        app:cardUseCompatPadding="true"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/theme_text_secondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copy from"
                    android:textSize="12sp"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginEnd="8dp" />

                <Spinner
                    android:id="@+id/spinnerCopyRole"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:spinnerMode="dropdown"
                    android:tooltipText="Copy permissions from" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopyPermissions"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Copy"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvRoleName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Role:"
                    android:textColor="@color/theme_text_accent"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:textColor="@color/theme_text_primary"
                    android:layout_marginEnd="2dp" />

                <CheckBox
                    android:id="@+id/cbSelectAllPerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPermissions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUsersAccessList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressAccess"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnSavePermissions"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Save Permissions"
        android:textColor="@color/theme_btn_accent_text"
        android:backgroundTint="@color/theme_btn_accent_bg"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

</LinearLayout>
