<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Scope toggle: which app's remarks are being managed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_input_rounded"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tabRemarksWorker"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🚴 Worker"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabRemarksCallCenter"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="📞 Call Center"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Current Remarks"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/theme_text_primary" />

            <TextView
                android:id="@+id/btnOpenCreateRemark"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/theme_bg_card"
                android:backgroundTint="#E8380D"
                android:background="@drawable/bg_card_rounded"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="14dp">
            <LinearLayout
                android:id="@+id/chipGroupStatuses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/remarksListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvRemarksEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No remarks found"
            android:gravity="center"
            android:padding="20dp"
            android:textColor="@color/theme_text_muted"
            android:textSize="13sp"
            android:background="@drawable/bg_card_rounded"
            android:visibility="gone"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/inlineCreateRemarkPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="14dp"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ নতুন Remark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/theme_text_primary"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="বাংলা" android:textSize="10sp" android:textColor="@color/theme_text_muted"
                        android:textStyle="bold" android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/etRemarkBn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="বাংলা টেক্সট..."
                        android:textSize="13sp"
                        android:padding="8dp"
                        android:background="@drawable/bg_input_rounded"
                        android:inputType="text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="English" android:textSize="10sp" android:textColor="@color/theme_text_muted"
                        android:textStyle="bold" android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/etRemarkEn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="English text..."
                        android:textSize="13sp"
                        android:padding="8dp"
                        android:background="@drawable/bg_input_rounded"
                        android:inputType="text" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="→ Group:" android:textSize="12sp" android:textColor="@color/theme_text_secondary"
                    android:layout_marginEnd="8dp" />
                <Spinner
                    android:id="@+id/spinnerTargetStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAddRemark"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="যোগ করুন"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#E8380D"
                android:textColor="@color/theme_bg_card" />
        </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/remarksBusyOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/theme_overlay_bg"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tvRemarksBusy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="@color/theme_bg_card"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />
    </LinearLayout>
</FrameLayout>
