<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Salary Manager"
                android:textColor="@color/theme_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSalaryAdd"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_salary_add_circle"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="+"
                android:textAllCaps="false"
                android:textColor="@color/theme_btn_accent_text"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutAgentTypeChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@color/theme_bg_card"
            android:gravity="top"
            android:orientation="horizontal"
            android:padding="14dp"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/tvAgentSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/theme_text_primary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="end"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/btnAddSalaryModel"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Add salary model"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_add_24"
                        android:tint="@color/theme_text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Add model"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnEditAgentType"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Edit agent type"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_edit_24"
                        android:tint="@color/theme_text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Edit"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnDeleteAgentType"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="Delete agent type"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_delete_24"
                        android:tint="@color/theme_red" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Delete"
                        android:textColor="@color/theme_red"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSalaryEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_dark"
            android:gravity="center"
            android:padding="24dp"
            android:text="No commission models yet."
            android:textColor="@color/theme_text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutSalaryModelList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/layoutSalaryEditor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/theme_bg_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Edit model"
                android:textColor="@color/theme_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model name"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etSalaryModelName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@color/theme_bg_inner"
                android:inputType="textCapWords"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/theme_text_primary"
                android:textColorHint="@color/theme_text_muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Slug"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etSalaryModelSlug"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@color/theme_bg_inner"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/theme_text_primary"
                android:textColorHint="@color/theme_text_muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Commission type"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinnerCommissionType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@color/theme_bg_inner"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Document delivery rate"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etDocumentRate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@color/theme_bg_inner"
                android:inputType="numberDecimal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/theme_text_primary"
                android:textColorHint="@color/theme_text_muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Document pickup rate"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etDocumentPickupRate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="14dp"
                android:background="@color/theme_bg_inner"
                android:inputType="numberDecimal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/theme_text_primary"
                android:textColorHint="@color/theme_text_muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Delivery Slabs"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutSlabRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvSlabWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@color/theme_bg_yellow"
                android:lineSpacingExtra="3dp"
                android:padding="10dp"
                android:textColor="@color/theme_yellow"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnAddSlab"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"
                android:backgroundTint="@color/theme_bg_inner"
                android:text="Add delivery slab"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_accent"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Pickup Slabs"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutPickupSlabRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvPickupSlabWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@color/theme_bg_yellow"
                android:lineSpacingExtra="3dp"
                android:padding="10dp"
                android:textColor="@color/theme_yellow"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnAddPickupSlab"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"
                android:backgroundTint="@color/theme_bg_inner"
                android:text="Add pickup slab"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_accent"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvPreviewResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@color/theme_bg_inner"
                android:lineSpacingExtra="4dp"
                android:padding="12dp"
                android:textColor="@color/theme_text_primary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCancelSalaryModel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/theme_bg_inner"
                    android:minWidth="0dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_secondary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnSaveSalaryModel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:backgroundTint="@color/theme_btn_accent_bg"
                    android:minWidth="0dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Save"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_btn_accent_text"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
