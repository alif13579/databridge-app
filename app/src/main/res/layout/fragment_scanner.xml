<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="#12122A">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parcel Scanner"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_marginBottom="12dp" />

        <!-- Count Badges -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="#1A1A2E"
                android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦 Total"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="#1A1A2E"
                android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvCameraCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#00C6FF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷 Camera"
                    android:textSize="9sp"
                    android:textColor="#4ab8d4"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="#1A1A2E">
                <TextView android:id="@+id/tvManualCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffd200" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Manual"
                    android:textSize="9sp"
                    android:textColor="#c9a84c"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 3 Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button android:id="@+id/btnSingleScan"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="◎ Single"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:textSize="12sp"
                android:background="@drawable/btn_scan_camera"
                android:layout_marginEnd="4dp" />

            <Button android:id="@+id/btnBatchScan"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⚡ Batch"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="12sp"
                android:background="@drawable/btn_mode_batch"
                android:layout_marginEnd="4dp" />

            <Button android:id="@+id/btnManual"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="✏️ Manual"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:textSize="12sp"
                android:background="@drawable/btn_scan_manual" />
        </LinearLayout>

        <!-- Tab chips: New Scan | All Scans -->
        <LinearLayout
            android:id="@+id/layoutTabChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/chipNewScan"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="📋 New Scan"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/chipAllScans"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="📦 All Scans"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Empty State -->
    <TextView android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="📦\n\nNo parcels scanned yet\n\nUse Single, Batch or Manual to begin"
        android:textAlignment="center"
        android:textColor="#444444"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="visible"
        android:padding="40dp"
        android:lineSpacingExtra="4dp" />

    <!-- Scan List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvScans"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false" />

    <!-- Upload Button (hidden until items exist) -->
    <Button android:id="@+id/btnUpload"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:layout_marginTop="4dp"
        android:text="☁ Upload Parcels"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:textSize="14sp"
        android:background="@drawable/btn_upload"
        android:visibility="gone" />

</LinearLayout>
