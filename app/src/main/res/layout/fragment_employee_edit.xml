<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Employee"
            android:textColor="@color/theme_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvEmployeeUid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/theme_text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="20dp"/>

        <!-- System ID -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="System ID" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etSystemId"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Auto-generated"
            android:textColor="@color/theme_text_primary" android:textColorHint="@color/theme_text_secondary"
            android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="12dp"
            android:textSize="14sp" android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <!-- Employee ID -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Employee ID" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etEmployeeId"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="e.g. EMP001"
            android:textColor="@color/theme_text_primary" android:textColorHint="@color/theme_text_secondary"
            android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="12dp"
            android:textSize="14sp" android:inputType="textCapCharacters|textNoSuggestions"
            android:layout_marginBottom="12dp"/>

        <!-- Display Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Full Name *" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etEmployeeName"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Full name"
            android:textColor="@color/theme_text_primary" android:textColorHint="@color/theme_text_secondary"
            android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="12dp"
            android:textSize="14sp" android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <!-- Email -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Email" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etEmployeeEmail"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="email@company.com"
            android:textColor="@color/theme_text_primary" android:textColorHint="@color/theme_text_secondary"
            android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="12dp"
            android:textSize="14sp" android:inputType="textEmailAddress"
            android:layout_marginBottom="12dp"/>

        <!-- Phone -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Phone" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etEmployeePhone"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="+880..."
            android:textColor="@color/theme_text_primary" android:textColorHint="@color/theme_text_secondary"
            android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="12dp"
            android:textSize="14sp" android:inputType="phone"
            android:layout_marginBottom="12dp"/>

        <!-- Designation -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Designation" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etDesignation"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="e.g. Senior Developer, Team Lead"
            android:textColor="@color/theme_text_primary" android:textColorHint="@color/theme_text_secondary"
            android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="12dp"
            android:textSize="14sp" android:inputType="textCapWords"
            android:layout_marginBottom="12dp"/>

        <!-- Role -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Role *" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerEmployeeRole"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/theme_bg_card" android:paddingStart="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- Status -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Status" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerStatus"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/theme_bg_card" android:paddingStart="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- Branch (dropdown picker) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Branch" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <RelativeLayout
            android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/btnSelectBranch"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="Tap to select branch ▾"
                android:textColor="@color/theme_text_secondary"
                android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="44dp"
                android:gravity="center_vertical"
                android:clickable="true" android:focusable="true"/>
            <TextView
                android:id="@+id/btnClearBranch"
                android:layout_width="44dp" android:layout_height="match_parent"
                android:text="✕"
                android:textColor="#ff4444" android:textSize="16sp"
                android:gravity="center"
                android:layout_alignParentEnd="true"
                android:clickable="true" android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone"/>
        </RelativeLayout>
        <TextView
            android:id="@+id/tvBranchSelected"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="None selected"
            android:textColor="@color/theme_text_secondary" android:textSize="12sp"
            android:paddingStart="4dp"
            android:layout_marginBottom="24dp"/>

        <!-- Optional Agent Type toggle -->
        <TextView
            android:id="@+id/btnToggleAgentType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Agent Type"
            android:textColor="@color/theme_text_secondary"
            android:textSize="13sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Optional Agent Type Container -->
        <LinearLayout
            android:id="@+id/llAgentType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Agent Type" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp">
                <Spinner
                    android:id="@+id/spinnerAgentType"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/theme_bg_card"
                    android:paddingStart="12dp"
                    android:paddingEnd="44dp"/>
                <TextView
                    android:id="@+id/btnClearAgentType"
                    android:layout_width="44dp"
                    android:layout_height="match_parent"
                    android:text="✕"
                    android:textColor="#ff4444"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_alignParentEnd="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="gone"/>
            </RelativeLayout>
        </LinearLayout>

        <!-- Optional Salary Type toggle -->
        <TextView
            android:id="@+id/btnToggleTypeModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Salary Type"
            android:textColor="@color/theme_text_secondary"
            android:textSize="13sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Optional Salary Type Container -->
        <LinearLayout
            android:id="@+id/llTypeModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Salary Type" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp">
                <Spinner
                    android:id="@+id/spinnerSalaryType"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/theme_bg_card"
                    android:paddingStart="12dp"
                    android:paddingEnd="44dp"/>
                <TextView
                    android:id="@+id/btnClearSalaryType"
                    android:layout_width="44dp"
                    android:layout_height="match_parent"
                    android:text="✕"
                    android:textColor="#ff4444"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_alignParentEnd="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="gone"/>
            </RelativeLayout>
        </LinearLayout>

        <!-- Optional Salary Model toggle -->
        <TextView
            android:id="@+id/btnToggleSalaryModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Salary Model"
            android:textColor="@color/theme_text_secondary"
            android:textSize="13sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Optional Salary Model Container -->
        <LinearLayout
            android:id="@+id/llSalaryModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Salary Model" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp">
                <Spinner
                    android:id="@+id/spinnerSalaryModel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/theme_bg_card"
                    android:paddingStart="12dp"
                    android:paddingEnd="44dp"/>
                <TextView
                    android:id="@+id/btnClearSalaryModel"
                    android:layout_width="44dp"
                    android:layout_height="match_parent"
                    android:text="✕"
                    android:textColor="#ff4444"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_alignParentEnd="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="gone"/>
            </RelativeLayout>
        </LinearLayout>

        <!-- Optional Fixed Amount toggle -->
        <TextView
            android:id="@+id/btnToggleFixedAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add Salary Amount"
            android:textColor="@color/theme_text_secondary"
            android:textSize="13sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Optional Fixed Amount Container -->
        <LinearLayout
            android:id="@+id/llFixedAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Fixed Salary Amount" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etFixedAmount"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:hint="e.g. 20000"
                android:textColor="@color/theme_text_primary" android:textColorHint="@color/theme_text_secondary"
                android:background="@color/theme_bg_card" android:paddingStart="12dp" android:paddingEnd="12dp"
                android:textSize="14sp" android:inputType="number"
                android:layout_marginBottom="12dp"/>
        </LinearLayout>

        

        <!-- Buttons -->
        <Button
            android:id="@+id/btnSaveEmployee"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Save Changes"
            android:textColor="@color/theme_btn_accent_text"
            android:backgroundTint="@color/theme_btn_accent_bg"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnCancelEmployee"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Cancel"
            android:textColor="@color/theme_text_secondary"
            android:backgroundTint="@color/theme_bg_card"/>

    </LinearLayout>
</ScrollView>
