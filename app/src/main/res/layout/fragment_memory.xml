<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeMemory"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_bg_app">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <!-- Header with Add Button and Filters -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memory"
                android:textColor="@color/theme_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>
            <LinearLayout
                android:id="@+id/layoutHeaderFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btnToggleForm"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <Button
                        android:id="@+id/btnDateFrom"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="72dp"
                        android:text="From"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="12sp"
                        android:backgroundTint="@color/theme_bg_card"/>
                    <ImageButton
                        android:id="@+id/btnClearDateFrom"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/theme_text_secondary"
                        android:visibility="gone"/>
                </LinearLayout>

        <TextView
            android:id="@+id/tvMemoryError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_red"
            android:textSize="12sp"
            android:background="@color/theme_bg_card"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_marginBottom="10dp"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="match_parent"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <Button
                        android:id="@+id/btnDateTo"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="72dp"
                        android:text="To"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="12sp"
                        android:backgroundTint="@color/theme_bg_card"/>
                    <ImageButton
                        android:id="@+id/btnClearDateTo"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/theme_text_secondary"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>
            <ImageButton
                android:id="@+id/btnToggleForm"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_add"
                app:tint="@color/theme_text_accent"/>
        </RelativeLayout>

        <!-- Fixed Salary Info layout -->
        <LinearLayout
            android:id="@+id/layoutFixedInfo"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@color/theme_bg_card"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tvFixedInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/theme_text_primary"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Variable entry disabled"
                android:textColor="#ffb347"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Stats Dashboard Block at the Top -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/theme_bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- Header row: title + collapse/expand arrow. Tapping anywhere on this row
                 toggles layoutSummaryContent below — summary box eats a lot of vertical
                 space, so agents can collapse it once they've checked it. -->
            <LinearLayout
                android:id="@+id/rowSummaryHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Summary (current date range)"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <ImageView
                    android:id="@+id/ivSummaryArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/arrow_up_float"
                    app:tint="@color/theme_text_secondary"
                    android:contentDescription="Collapse/expand summary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSummaryContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvMemorySum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="৳0"
                        android:textColor="#00ff99"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Average" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvMemoryAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="৳0"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Max / Min" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvMemoryMaxMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="৳0 / ৳0"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Delivery / Pickup totals row (new) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Delivery count" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvMemoryDeliveryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pickup count" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvMemoryPickupCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg success" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvSuccessAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/theme_text_accent"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Max success" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvSuccessMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#00ff99"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Min success" android:textColor="@color/theme_text_secondary" android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvSuccessMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#ffb347"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Date Range Filter Buttons moved to header -->

        <!-- Filter info description & Today total info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <TextView
                android:id="@+id/tvFilters"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Filters: Any → Any"
                android:textColor="@color/theme_text_secondary"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvTodayTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today: ৳0"
                android:textColor="@color/theme_text_accent"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Fields Entry Section (Delivery + Pickup) -->
        <LinearLayout
            android:id="@+id/layoutMemoryForm"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <Button
                    android:id="@+id/btnEntryDate"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="140dp"
                    android:text="Select Date"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="13sp"
                    android:backgroundTint="@color/theme_bg_card"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/theme_bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Delivery"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Parcel Delivery -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parcel Delivery"
                        android:textColor="@color/theme_text_accent"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Assigned" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etParcelAssigned"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                        <View
                            android:layout_width="12dp"
                            android:layout_height="match_parent"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Delivered" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etParcelCount"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Document Delivery -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Document Delivery"
                        android:textColor="@color/theme_text_accent"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Assigned" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etDocAssigned"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                        <View
                            android:layout_width="12dp"
                            android:layout_height="match_parent"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Delivered" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etDocCount"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Pickup Section collapsible -->
            <LinearLayout
                android:id="@+id/layoutPickupHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@color/theme_bg_card"
                android:layout_marginBottom="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pickup"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <ImageButton
                    android:id="@+id/btnTogglePickup"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="@color/theme_text_accent"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPickupSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/theme_bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <!-- Parcel Pickup -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parcel Pickup"
                        android:textColor="@color/theme_text_accent"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Assigned" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etParcelPickupAssigned"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                        <View
                            android:layout_width="12dp"
                            android:layout_height="match_parent"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Picked" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etParcelPickup"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Document Pickup -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Document Pickup"
                        android:textColor="@color/theme_text_accent"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Assigned" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etDocPickupAssigned"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                        <View
                            android:layout_width="12dp"
                            android:layout_height="match_parent"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Picked" android:textColor="@color/theme_text_secondary" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etDocPickup"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:hint="0"
                                android:textColor="@color/theme_text_primary"
                                android:textColorHint="@color/theme_text_secondary"
                                android:background="@color/theme_bg_card_inner"
                                android:paddingStart="12dp"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvFormPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/theme_text_primary"
                android:textSize="12sp"
                android:padding="14dp"
                android:background="@color/theme_bg_card"
                android:layout_marginBottom="12dp"/>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveMemory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Save Entry"
                android:textColor="@color/theme_bg_app"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:backgroundTint="@color/theme_text_accent"/>
        </LinearLayout>

        <!-- RecyclerView List of Memories -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMemory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
