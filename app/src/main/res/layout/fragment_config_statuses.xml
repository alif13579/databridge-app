<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Current Status"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/btnOpenCreateStatus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/theme_bg_card"
                android:backgroundTint="#E8380D"
                android:background="@drawable/bg_card_rounded"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/statusListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvStatusEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No status found yet, please create."
            android:gravity="center"
            android:padding="20dp"
            android:textColor="@color/theme_text_muted"
            android:textSize="13sp"
            android:background="@drawable/bg_card_rounded"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/inlineCreateStatusPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="14dp"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="+ নতুন Status" android:textSize="12sp" android:textStyle="bold"
                android:textColor="@color/theme_text_primary" android:layout_marginBottom="12dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="KEY" android:textSize="10sp" android:textColor="@color/theme_text_muted"
                android:textStyle="bold" android:layout_marginBottom="4dp" />
            <EditText android:id="@+id/etNewStatusKey" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="e.g. PARTIAL"
                android:textSize="13sp" android:padding="8dp"
                android:background="@drawable/bg_input_rounded"
                android:inputType="textCapCharacters" android:layout_marginBottom="10dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="বাংলা" android:textSize="10sp" android:textColor="@color/theme_text_muted"
                        android:textStyle="bold" android:layout_marginBottom="4dp" />
                    <EditText android:id="@+id/etNewStatusBn" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="বাংলা..."
                        android:textSize="13sp" android:padding="8dp"
                        android:background="@drawable/bg_input_rounded" android:inputType="text" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="English" android:textSize="10sp" android:textColor="@color/theme_text_muted"
                        android:textStyle="bold" android:layout_marginBottom="4dp" />
                    <EditText android:id="@+id/etNewStatusEn" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="English..."
                        android:textSize="13sp" android:padding="8dp"
                        android:background="@drawable/bg_input_rounded" android:inputType="text" />
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Priority (বেশি = আগে দেখাবে)" android:textSize="10sp"
                android:textColor="@color/theme_text_muted" android:textStyle="bold" android:layout_marginBottom="4dp" />
            <EditText android:id="@+id/etNewStatusPriority" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="0"
                android:textSize="13sp" android:padding="8dp"
                android:background="@drawable/bg_input_rounded"
                android:inputType="number" android:layout_marginBottom="10dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Color" android:textSize="10sp" android:textColor="@color/theme_text_muted"
                android:textStyle="bold" android:layout_marginBottom="6dp" />
            <LinearLayout
                android:id="@+id/colorPickerNew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp" />
            <TextView android:id="@+id/tvColorPreviewNew"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Preview" android:textSize="12sp" android:textStyle="bold"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_marginBottom="12dp" />

            <TextView android:id="@+id/tvCreateError" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="#EF4444" android:visibility="gone" android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btnCreateStatus" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="তৈরি করুন"
                android:textSize="13sp" android:textStyle="bold"
                android:backgroundTint="#E8380D" android:textColor="@color/theme_bg_card" />
        </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/statusBusyOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/theme_overlay_bg"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tvStatusBusy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="@color/theme_bg_card"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />
    </LinearLayout>
</FrameLayout>
