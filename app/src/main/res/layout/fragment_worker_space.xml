<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header"
                android:padding="10dp"
                android:paddingBottom="6dp">

                <!-- Top row: avatar + name + COD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/twAvatarIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_avatar_gradient"
                            android:gravity="center"
                            android:text="📦"
                            android:textSize="14dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:id="@+id/twRoleLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DELIVERY AGENT"
                                android:textSize="12sp"
                                android:textColor="@color/theme_accent"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/twAgentInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sonia Akter · Sonargaon Hub"
                                android:textSize="11sp"
                                android:textColor="@color/theme_text_secondary"
                                android:layout_marginTop="1dp" />

                            <!-- Sort by chip — inline under agent info (same compact
                                 pattern as CallCenter's filter chips) instead of its own
                                 full-width row, so the header doesn't waste vertical space
                                 on a near-empty row just for one small dropdown. -->
                            <TextView
                                android:id="@+id/tvSortByDropdown"
                                android:layout_width="wrap_content"
                                android:layout_height="24dp"
                                android:text="🔁 Attempt ▾"
                                android:textSize="10sp"
                                android:gravity="center"
                                android:paddingStart="7dp"
                                android:paddingEnd="7dp"
                                android:background="@drawable/bg_filter_chip_active"
                                android:textColor="@android:color/white"
                                android:layout_marginTop="5dp"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's COD"
                            android:textSize="10sp"
                            android:textColor="@color/theme_text_secondary" />

                        <TextView
                            android:id="@+id/twTodayCod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳0"
                            android:textSize="16sp"
                            android:textColor="@color/theme_accent"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <Spinner
                            android:id="@+id/spinnerRunType"
                            android:layout_width="90dp"
                            android:layout_height="26dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_search_bar"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>

                    <!-- Collapse arrow — toggles layoutStatsCollapsible below, same
                         mechanism as CallCenterFragment's tvCcaCollapseArrow. -->
                    <TextView
                        android:id="@+id/twCollapseArrow"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:layout_gravity="top"
                        android:text="▼"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:textColor="@color/theme_text_secondary"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                                <!-- Search Bar -->
                <LinearLayout
                    android:id="@+id/layoutSearchBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_bar"
                    android:padding="7dp"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="15sp"
                        android:alpha="0.5" />

                    <EditText
                        android:id="@+id/twSearchInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Search by phone, ID or COD..."
                        android:textColorHint="@color/theme_text_secondary"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="13sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:inputType="text"
                        android:maxLines="1"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/twSearchClear"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="✕"
                        android:textSize="11sp"
                        android:textColor="@color/theme_text_secondary"
                        android:gravity="center"
                        android:visibility="gone"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:id="@+id/twSearchScan"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="📷"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginStart="4dp" />
                </LinearLayout>


<!-- Search result count -->
                <TextView
                    android:id="@+id/twSearchCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginTop="4dp"
                    android:paddingStart="2dp"
                    android:visibility="gone" />

                <!-- Collapsible section: Stats grid — collapsed by default so the header
                     doesn't eat screen space; twCollapseArrow above toggles this, same
                     pattern as CallCenterFragment's layoutCcaCollapsibleSection. -->
                <LinearLayout
                    android:id="@+id/layoutStatsCollapsible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <!-- Stats grid: 3 columns -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3"
                        android:gravity="center">

                        <LinearLayout
                            android:id="@+id/layoutStatTotal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp"
                            android:background="@drawable/bg_stat_card"
                            android:layout_marginEnd="5dp">

                            <TextView
                                android:id="@+id/twStatTotalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/theme_text_primary"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textSize="10sp"
                                android:textColor="@color/theme_text_secondary"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutStatConfirmed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp"
                            android:background="@drawable/bg_stat_card"
                            android:layout_marginEnd="5dp">

                            <TextView
                                android:id="@+id/twStatConfirmedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/theme_green"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Confirmed"
                                android:textSize="10sp"
                                android:textColor="@color/theme_text_secondary"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutStatPending"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp"
                            android:background="@drawable/bg_stat_card">

                            <TextView
                                android:id="@+id/twStatPendingValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/theme_yellow"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textSize="10sp"
                                android:textColor="@color/theme_text_secondary"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <!-- /layoutStatsCollapsible -->
            </LinearLayout>

            <!-- Filter Tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutFilterTabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </HorizontalScrollView>

            <!-- Shown only when the (relevant) run's status is "closed", so the agent
                 immediately knows they can't get new parcels for that run right now. -->
            <TextView
                android:id="@+id/twRunClosedBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FEF3C7"
                android:textColor="#92400E"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="10dp"
                android:visibility="gone"
                android:text="🔒 Run বন্ধ হয়ে গেছে" />

            <!-- Pull-to-refresh + Parcel List -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false">

                <ProgressBar
                    android:id="@+id/twProgressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/twEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="📭\n\nNo parcels found"
                    android:textSize="14sp"
                    android:textColor="@color/theme_text_secondary"
                    android:padding="40dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvParcelList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />
            </FrameLayout>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

</FrameLayout>
