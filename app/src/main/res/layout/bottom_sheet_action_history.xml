<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/theme_bg_card"
    android:padding="20dp"
    android:paddingBottom="32dp"
    android:maxHeight="500dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@color/theme_border"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/twHistoryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Action History"
                android:textSize="15sp"
                android:textColor="@color/theme_text_primary"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/twHistorySub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DB-2202 · Fatema Begum"
                android:textSize="11sp"
                android:textColor="@color/theme_text_secondary"
                android:layout_marginTop="2dp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnHistoryClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✕"
            android:textSize="13sp"
            android:textColor="@color/theme_text_secondary"
            android:gravity="center"
            android:background="@color/theme_bg_inner"
            android:clickable="true"
            android:focusable="true"
            android:includeFontPadding="false" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layoutTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>
