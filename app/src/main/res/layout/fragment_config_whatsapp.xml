<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="প্রতিটা Template Remark-এর সাথে link করলে, সেই remark ব্যবহার হলে WhatsApp-এ auto message দেখাবে (send করার আগে edit করা যাবে)।"
            android:textSize="11sp"
            android:textColor="@color/theme_text_muted"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WhatsApp Templates"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/btnOpenCreateTemplate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/theme_bg_card"
                android:backgroundTint="#25D366"
                android:background="@drawable/bg_card_rounded"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/templateListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvTemplateEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="কোনো WhatsApp template নেই, তৈরি করুন।"
            android:gravity="center"
            android:padding="20dp"
            android:textColor="@color/theme_text_muted"
            android:textSize="13sp"
            android:background="@drawable/bg_card_rounded"
            android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/whatsappBusyOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/theme_overlay_bg"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tvWhatsappBusy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="@color/theme_bg_card"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />
    </LinearLayout>
</FrameLayout>
